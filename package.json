{
  "name": "mini-blockchain",
  "version": "1.0.0",
  "description": "Dự án mô phỏng Blockchain đơn giản cho tiểu luận cuối kỳ",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "node1": "cross-env PORT=3000 node src/server.js",
    "node2": "cross-env PORT=3001 node src/server.js",
    "node3": "cross-env PORT=3002 node src/server.js",
    "node4": "cross-env PORT=3003 node src/server.js",
    "node5": "cross-env PORT=3004 node src/server.js",
    "network": "concurrently \"npm run node1\" \"npm run node2\" \"npm run node3\""
  },
  "keywords": [
    "blockchain",
    "nodejs",
    "express",
    "pow"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.2",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "elliptic": "^6.6.1",
    "express": "^4.18.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0"
  }
}